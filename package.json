{
  "name": "crow-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@latest",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun run prettier src/ --write",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/preact": "^4.0.10",
    "@astrojs/tailwind": "^6.0.2",
    "@b3-crow/ui-kit": "^0.0.33",
    "@preact/signals": "^2.0.4",
    "astro": "^5.10.1",
    "lucide-preact": "^0.561.0",
    "preact": "^10.28.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint-react/eslint-plugin": "^2.3.5",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.0.17",
    "@types/node": "^20.19.25",
    "eslint": "^9",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.8.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
