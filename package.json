{
  "name": "next",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@latest",
  "scripts": {
    "dev": "next dev --turbopack --port 3000 | pino-pretty",
    "build": "next build --turbopack",
    "build:cloudflare": "opennextjs-cloudflare build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun run prettier src/ --write",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "deploy:prod": "opennextjs-cloudflare build && wrangler deploy --env production",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "cf-typegen:prod": "wrangler types --env production --env-interface CloudflareEnvProd ./cloudflare-env.production.d.ts",
    "cf:migrate:dev": "wrangler d1 migrations apply DB_MAIN --env dev --remote",
    "cf:migrate": "wrangler d1 migrations apply DB_MAIN --remote",
    "cf:migrate:prod": "wrangler d1 migrations apply DB_MAIN --env production --remote",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "test:e2e": "playwright test"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.968.0",
    "@b3-crow/ui-kit": "^0.0.33",
    "@opennextjs/cloudflare": "^1.14.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.16",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.44.7",
    "framer-motion": "^12.26.2",
    "ky": "^1.14.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.561.0",
    "next": "15.5.6",
    "pino": "^9.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.0.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint-react/eslint-plugin": "^2.6.0",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.19.29",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.59.1"
  }
}
